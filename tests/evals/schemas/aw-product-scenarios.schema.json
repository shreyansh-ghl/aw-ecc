{
  "$id": "aw-product-scenarios.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "layer", "cases"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "aw.eval.product-scenarios.v1"
    },
    "layer": {
      "type": "string",
      "const": "product"
    },
    "cases": {
      "type": "array",
      "minItems": 8,
      "items": {
        "$ref": "aw-scenario-case.schema.json"
      }
    }
  }
}
