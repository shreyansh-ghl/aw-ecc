{
  "$id": "aw-revex-history-benchmark.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "benchmarkName",
    "packKey",
    "packLabel",
    "comparisonMode",
    "requestedPerRepo",
    "generatedAt",
    "repos",
    "cases",
    "judgeRubricPath",
    "packsPath"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "aw.eval.revex-history-benchmark.v3"
    },
    "benchmarkName": {
      "type": "string",
      "const": "aw-revex-history-benchmark"
    },
    "packKey": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 3
    },
    "packLabel": {
      "type": "string",
      "minLength": 3
    },
    "comparisonMode": {
      "type": "string",
      "enum": ["pr_parity"]
    },
    "requestedPerRepo": {
      "type": "integer",
      "minimum": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 10
    },
    "judgeRubricPath": {
      "type": "string",
      "pattern": "^tests/evals/fixtures/"
    },
    "packsPath": {
      "type": "string",
      "pattern": "^tests/evals/fixtures/"
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repoKey",
          "domain",
          "repoRelativePath",
          "repoPathExists",
          "shallow",
          "visibleCommitCount",
          "selectedCaseCount",
          "warnings"
        ],
        "properties": {
          "repoKey": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "minLength": 3
          },
          "domain": {
            "type": "string",
            "enum": ["frontend", "backend", "fullstack", "infra", "mixed"]
          },
          "repoRelativePath": {
            "type": "string",
            "minLength": 3
          },
          "repoPathExists": {
            "type": "boolean"
          },
          "shallow": {
            "type": "boolean"
          },
          "visibleCommitCount": {
            "type": "integer",
            "minimum": 0
          },
          "selectedCaseCount": {
            "type": "integer",
            "minimum": 0
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            }
          }
        }
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "layer",
          "repoKey",
          "domain",
          "repoRelativePath",
          "productArea",
          "commitSha",
          "parentSha",
          "commitDate",
          "commitType",
          "commitSubject",
          "changedFileCount",
          "insertions",
          "deletions",
          "changedFiles",
          "promptLevel",
          "changeKind",
          "affectedSurface",
          "userPrompt",
          "successCriteria",
          "verificationExpectations",
          "inferredRoute",
          "expectedPrimarySkill",
          "recommendedSupportingSkills",
          "storedArtifacts",
          "warnings"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "minLength": 6
          },
          "layer": {
            "type": "string",
            "const": "history"
          },
          "packKey": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "minLength": 3
          },
          "packLabel": {
            "type": "string",
            "minLength": 3
          },
          "comparisonMode": {
            "type": "string",
            "enum": ["pr_parity"]
          },
          "repoKey": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "minLength": 3
          },
          "domain": {
            "type": "string",
            "enum": ["frontend", "backend", "fullstack", "infra", "mixed"]
          },
          "repoRelativePath": {
            "type": "string",
            "minLength": 3
          },
          "productArea": {
            "type": "string",
            "minLength": 2
          },
          "commitSha": {
            "type": "string",
            "pattern": "^[a-f0-9]{7,40}$"
          },
          "parentSha": {
            "type": "string",
            "pattern": "^[a-f0-9]{7,40}$"
          },
          "commitDate": {
            "type": "string",
            "minLength": 10
          },
          "commitType": {
            "type": "string",
            "minLength": 3
          },
          "commitScope": {
            "type": ["string", "null"]
          },
          "commitSubject": {
            "type": "string",
            "minLength": 5
          },
          "changedFileCount": {
            "type": "integer",
            "minimum": 1
          },
          "insertions": {
            "type": "integer",
            "minimum": 0
          },
          "deletions": {
            "type": "integer",
            "minimum": 0
          },
          "changedFiles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "promptLevel": {
            "type": "string",
            "const": "sparse_ticket"
          },
          "changeKind": {
            "type": "string",
            "enum": ["bugfix", "feature", "refactor", "test-hardening", "implementation"]
          },
          "affectedSurface": {
            "type": "string",
            "minLength": 3
          },
          "taskCard": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "taskSummary",
              "taskType",
              "expectedSurface",
              "baselineChangedFiles",
              "successSignals",
              "forbiddenScope",
              "comparisonMode",
              "routeExpectation"
            ],
            "properties": {
              "taskSummary": {
                "type": "string",
                "minLength": 12
              },
              "taskType": {
                "type": "string",
                "enum": ["bugfix", "feature", "refactor", "test-hardening", "implementation"]
              },
              "expectedSurface": {
                "type": "string",
                "minLength": 3
              },
              "baselineChangedFiles": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 3
                }
              },
              "successSignals": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "string",
                  "minLength": 8
                }
              },
              "forbiddenScope": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "string",
                  "minLength": 8
                }
              },
              "comparisonMode": {
                "type": "string",
                "enum": ["pr_parity"]
              },
              "routeExpectation": {
                "type": "string",
                "enum": ["/aw:build", "/aw:investigate", "/aw:test"]
              }
            }
          },
          "baselineCard": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "title",
              "commitSha",
              "parentSha",
              "changedFileCount",
              "totalLinesChanged",
              "changedFiles"
            ],
            "properties": {
              "title": {
                "type": "string",
                "minLength": 5
              },
              "commitSha": {
                "type": "string",
                "pattern": "^[a-f0-9]{7,40}$"
              },
              "parentSha": {
                "type": "string",
                "pattern": "^[a-f0-9]{7,40}$"
              },
              "changedFileCount": {
                "type": "integer",
                "minimum": 1
              },
              "totalLinesChanged": {
                "type": "integer",
                "minimum": 1
              },
              "changedFiles": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 3
                }
              }
            }
          },
          "userPrompt": {
            "type": "string",
            "minLength": 40
          },
          "successCriteria": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "string",
              "minLength": 8
            }
          },
          "verificationExpectations": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "string",
              "minLength": 8
            }
          },
          "inferredRoute": {
            "type": "string",
            "enum": ["/aw:build", "/aw:investigate", "/aw:test"]
          },
          "expectedPrimarySkill": {
            "type": "string",
            "enum": ["aw-build", "aw-investigate", "aw-test"]
          },
          "recommendedSupportingSkills": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "storedArtifacts": {
            "type": "object",
            "additionalProperties": false,
            "required": ["problem", "baselinePr", "baselineMetadata"],
            "properties": {
              "problem": {
                "type": "string",
                "pattern": "^tests/evals/fixtures/revex-history/"
              },
              "baselinePr": {
                "type": "string",
                "pattern": "^tests/evals/fixtures/revex-history/"
              },
              "baselineMetadata": {
                "type": "string",
                "pattern": "^tests/evals/fixtures/revex-history/"
              }
            }
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
