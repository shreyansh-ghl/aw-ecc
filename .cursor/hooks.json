{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "bash -lc 'exec bash \"${CURSOR_PLUGIN_ROOT:-$HOME/.cursor}/hooks/session-start.sh\"'",
        "event": "sessionStart",
        "description": "Load AW routing context at session start"
      }
    ],
    "sessionEnd": [
      {
        "command": "bash -lc 'exec node \"${CURSOR_PLUGIN_ROOT:-$HOME/.cursor}/hooks/session-end.js\"'",
        "event": "sessionEnd",
        "description": "Persist session state and evaluate patterns"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "npx block-no-verify@1.1.2",
        "event": "beforeShellExecution",
        "description": "Block git hook-bypass flag to protect pre-commit, commit-msg, and pre-push hooks from being skipped"
      },
      {
        "command": "bash -lc 'exec node \"${CURSOR_PLUGIN_ROOT:-$HOME/.cursor}/hooks/before-shell-execution.js\"'",
        "event": "beforeShellExecution",
        "description": "Tmux dev server blocker, tmux reminder, git push review"
      }
    ],
    "afterShellExecution": [
      {
        "command": "bash -lc 'exec node \"${CURSOR_PLUGIN_ROOT:-$HOME/.cursor}/hooks/after-shell-execution.js\"'",
        "event": "afterShellExecution",
        "description": "PR URL logging, build analysis"
      }
    ],
    "afterFileEdit": [
      {
        "command": "bash -lc 'exec node \"${CURSOR_PLUGIN_ROOT:-$HOME/.cursor}/hooks/after-file-edit.js\"'",
        "event": "afterFileEdit",
        "description": "Auto-format, TypeScript check, console.log warning"
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "bash -lc 'exec node \"${CURSOR_PLUGIN_ROOT:-$HOME/.cursor}/hooks/before-mcp-execution.js\"'",
        "event": "beforeMCPExecution",
        "description": "MCP audit logging and untrusted server warning"
      }
    ],
    "afterMCPExecution": [
      {
        "command": "bash -lc 'exec node \"${CURSOR_PLUGIN_ROOT:-$HOME/.cursor}/hooks/after-mcp-execution.js\"'",
        "event": "afterMCPExecution",
        "description": "MCP result logging"
      }
    ],
    "beforeReadFile": [
      {
        "command": "bash -lc 'exec node \"${CURSOR_PLUGIN_ROOT:-$HOME/.cursor}/hooks/before-read-file.js\"'",
        "event": "beforeReadFile",
        "description": "Warn when reading sensitive files (.env, .key, .pem)"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "bash -lc 'exec bash \"${CURSOR_PLUGIN_ROOT:-$HOME/.cursor}/hooks/before-submit-prompt.sh\"'",
        "event": "beforeSubmitPrompt",
        "description": "Inject compact AW routing and rule reminders on each prompt"
      }
    ],
    "subagentStart": [
      {
        "command": "bash -lc 'exec node \"${CURSOR_PLUGIN_ROOT:-$HOME/.cursor}/hooks/subagent-start.js\"'",
        "event": "subagentStart",
        "description": "Log agent spawning for observability"
      }
    ],
    "subagentStop": [
      {
        "command": "bash -lc 'exec node \"${CURSOR_PLUGIN_ROOT:-$HOME/.cursor}/hooks/subagent-stop.js\"'",
        "event": "subagentStop",
        "description": "Log agent completion"
      }
    ],
    "beforeTabFileRead": [
      {
        "command": "bash -lc 'exec node \"${CURSOR_PLUGIN_ROOT:-$HOME/.cursor}/hooks/before-tab-file-read.js\"'",
        "event": "beforeTabFileRead",
        "description": "Block Tab from reading secrets (.env, .key, .pem, credentials)"
      }
    ],
    "afterTabFileEdit": [
      {
        "command": "bash -lc 'exec node \"${CURSOR_PLUGIN_ROOT:-$HOME/.cursor}/hooks/after-tab-file-edit.js\"'",
        "event": "afterTabFileEdit",
        "description": "Auto-format Tab edits"
      }
    ],
    "preCompact": [
      {
        "command": "bash -lc 'exec node \"${CURSOR_PLUGIN_ROOT:-$HOME/.cursor}/hooks/pre-compact.js\"'",
        "event": "preCompact",
        "description": "Save state before context compaction"
      }
    ],
    "stop": [
      {
        "command": "bash -lc 'exec node \"${CURSOR_PLUGIN_ROOT:-$HOME/.cursor}/hooks/stop.js\"'",
        "event": "stop",
        "description": "Console.log audit on all modified files"
      }
    ]
  }
}
