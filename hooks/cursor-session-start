#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Locate the using-aw-skills session-start hook.
# Priority: repo-local > user-level installs > aw_registry.
CANDIDATES=(
  "$PLUGIN_ROOT/skills/using-aw-skills/hooks/session-start.sh"
  "$HOME/.cursor/skills/using-aw-skills/hooks/session-start.sh"
  "$HOME/.aw-ecc/skills/using-aw-skills/hooks/session-start.sh"
  "$HOME/.claude/skills/using-aw-skills/hooks/session-start.sh"
  "$HOME/.aw_registry/platform/core/skills/using-aw-skills/hooks/session-start.sh"
  "$HOME/.aw/.aw_registry/platform/core/skills/using-aw-skills/hooks/session-start.sh"
)

TARGET_SCRIPT=""
for candidate in "${CANDIDATES[@]}"; do
  if [[ -f "$candidate" ]]; then
    TARGET_SCRIPT="$candidate"
    break
  fi
done

if [[ -z "$TARGET_SCRIPT" ]]; then
  printf '{\n  "additional_context": "WARNING: AW session-start hook not found. AW skills unavailable."\n}\n'
  exit 0
fi

# Run the hook with /dev/null as stdin to prevent the inner script's stdin
# drain (`cat >/dev/null`) from hanging when no payload is piped.
RESULT="$(CURSOR_PLUGIN_ROOT="$PLUGIN_ROOT" bash "$TARGET_SCRIPT" </dev/null 2>/dev/null || true)"

if [[ -z "$RESULT" ]]; then
  printf '{\n  "additional_context": "WARNING: AW session-start hook produced empty output."\n}\n'
  exit 0
fi

# Convert hookSpecificOutput.additionalContext -> additional_context for Cursor.
# Uses printf instead of heredoc to avoid bash 5.3+ heredoc hang.
printf '%s' "$RESULT" | node -e '
  let input = "";
  process.stdin.setEncoding("utf8");
  process.stdin.on("data", chunk => input += chunk);
  process.stdin.on("end", () => {
    try {
      const parsed = JSON.parse(input || "{}");
      const context =
        (parsed && parsed.hookSpecificOutput && parsed.hookSpecificOutput.additionalContext) ||
        parsed.additional_context ||
        "";
      if (typeof context === "string" && context.trim()) {
        process.stdout.write(JSON.stringify({ additional_context: context }, null, 2) + "\n");
        return;
      }
    } catch {}
    process.stdout.write("{\"additional_context\": \"WARNING: Could not parse AW session-start output.\"}\n");
  });
'

exit 0
